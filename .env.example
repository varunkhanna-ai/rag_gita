# These API keys are completely optional. They are only needed if you want to use
# API-based LLMs (OpenRouter, Gemini, Groq) instead of the free local browser-based model.
# The default local model requires no API key and runs entirely in the browser.

OPENROUTER_API_KEY=
GEMINI_API_KEY=

# Cloud LLaMA: set this to enable the free cloud-hosted LLaMA provider.
# Get a free key at https://console.groq.com
GROQ_API_KEY=
